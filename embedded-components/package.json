{
  "name": "@jpmorgan-payments/embedded-finance-components",
  "version": "0.17.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "license": "Apache-2.0",
  "type": "module",
  "description": "Embedded Finance Components",
  "keywords": [
    "react",
    "components",
    "ui",
    "embedded-finance",
    "payments",
    "jpmorgan",
    "banking",
    "onboarding",
    "design-system",
    "typescript",
    "radix-ui",
    "tailwind",
    "financial-services",
    "fintech",
    "react-components",
    "ui-library",
    "component-library"
  ],
  "files": [
    "dist",
    "src/i18n",
    "changelog.json"
  ],
  "main": "./dist/umd/ef-components.js",
  "module": "./dist/esm/ef-components.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/esm/ef-components.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/umd/ef-components.js"
      }
    },
    "./i18n/config": {
      "types": "./src/i18n/config.ts",
      "import": "./src/i18n/config.ts",
      "require": "./src/i18n/config.ts"
    },
    "./i18n/en-US/*.json": "./src/i18n/en-US/*.json",
    "./i18n/es-US/*.json": "./src/i18n/es-US/*.json",
    "./i18n/fr-CA/*.json": "./src/i18n/fr-CA/*.json",
    "./changelog.json": "./changelog.json"
  },
  "scripts": {
    "build": "rimraf dist && tsc && cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build:analyze": "vite build --mode analyze",
    "dev": "vite",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 storybook build --disable-telemetry",
    "test": "npm run typecheck && npm run lint && vitest run --coverage --reporter=default --reporter=junit --outputFile.junit=coverage/junit/results.xml --testTimeout=45000 --retry=1",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:onboarding": "vitest run src/core/OnboardingFlow --coverage --coverage.include=src/core/OnboardingFlow/**/*.ts --coverage.include=src/core/OnboardingFlow/**/*.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "lint:styles": "cross-env ESLINT_STYLES=1 eslint . --cache --cache-location .eslintcache.styles",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "audit": "yarn audit --level moderate",
    "audit:fix": "yarn audit fix",
    "analyze": "vite build --mode analyze",
    "visualize": "vite-bundle-visualizer",
    "generate-api": "orval --config ./orval.config.mjs && yarn fix-generated-files && yarn prettify-generated-files",
    "fix-generated-files": "yarn replace '((?:\\s|\\<))(?!N)(\\d\\S*)Response' '$1N$2Response' ./src/api/generated/*",
    "prettify-generated-files": "npx prettier --write './src/api/generated/*'",
    "prettier": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "vitest": "vitest run",
    "vitest:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.18",
